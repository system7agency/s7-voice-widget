# =============================================================================
# Backend env vars — for the "Get a call" (outbound dial) feature ONLY.
# The chat + in-browser voice modes need NONE of these; they run fully in the
# browser with just the public agent id passed to the widget.
#
# These are SERVER-ONLY secrets. Never expose them to the browser.
# =============================================================================

# ElevenLabs public agent id (agent_...). Same id you pass to the widget.
ELEVENLABS_AGENT_ID=

# Phone-number id (phnum_...) assigned to the agent in the ElevenLabs dashboard.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# Secret ElevenLabs API key (sk_...). Used as the xi-api-key header.
ELEVENLABS_API_KEY=

# Optional: lock CORS to your embedding site's origin (default "*").
# e.g. https://www.acme.com
WIDGET_ALLOW_ORIGIN=*

# Optional: port for the standalone Express server (default 8787).
PORT=8787
